# ===== Build Service =====
BUILD_SERVICE_HOST=0.0.0.0
BUILD_SERVICE_PORT=8004
BUILD_SERVICE_RELOAD=false
BUILD_SERVICE_LOG_LEVEL=info

# Directory where uploaded source files are stored (relative to service root)
FILES_DIR=./files
FILE_REGISTRY_PATH=./file_registry.json

# ===== LLM / Embedding (routed through llm-gateway) =====
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=http://localhost:8002/v1
OPENAI_LLM_MODEL=gpt-4o
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large

# ===== Neo4j =====
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=12345678

# ===== Performance =====
MAX_WORKERS=4
BATCH_SIZE=100
ENTITY_BATCH_SIZE=50
CHUNK_BATCH_SIZE=100
EMBEDDING_BATCH_SIZE=64
GDS_MEMORY_LIMIT=6
GDS_CONCURRENCY=4

# ===== Graph Schema =====
# GRAPH_COMMUNITY_ALGORITHM=leiden   # leiden | sllpa
# GRAPH_CONFLICT_STRATEGY=manual_first

# ===== SEC Pipeline =====
# Set to false to use the generic document processor instead of SEC parser
SEC_PIPELINE_ENABLED=true

# ===== GCS =====
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_FILES_PREFIX=small/
