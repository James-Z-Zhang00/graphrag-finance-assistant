# ===== Search Service =====

# Network
SEARCH_SERVICE_HOST=0.0.0.0
SEARCH_SERVICE_PORT=8003
SEARCH_SERVICE_RELOAD=false
SEARCH_SERVICE_LOG_LEVEL=info

# LLM — point at the gateway, not OpenAI directly
OPENAI_BASE_URL=http://localhost:8002/v1
OPENAI_API_KEY=your-gateway-api-key
OPENAI_LLM_MODEL=gpt-4.1-nano
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large
TEMPERATURE=0.1
MAX_TOKENS=10000

# Neo4j — direct connection (search service owns the graph queries)
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=12345678
NEO4J_MAX_POOL_SIZE=10
NEO4J_REFRESH_SCHEMA=false

# Cache
CACHE_DIR=./cache
CACHE_MEMORY_ONLY=false
CACHE_EMBEDDING_PROVIDER=openai
