# ===== LLM Gateway =====

# Network
LLM_GATEWAY_HOST=0.0.0.0
LLM_GATEWAY_PORT=8002
LLM_GATEWAY_RELOAD=false
LLM_GATEWAY_LOG_LEVEL=info

# Auth
# Key that internal services (e.g. graphrag_agent) send to the gateway.
# Leave empty to disable auth in local dev.
GATEWAY_API_KEY=your-internal-gateway-key

# Upstream provider
# Point this at OpenAI, One-API, or any OpenAI-compatible endpoint.
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=sk-your-upstream-key

# Timeout in seconds for upstream requests (streaming holds the connection open)
REQUEST_TIMEOUT=120
